# =============================================================================
# Argus configuration — copy to `.env` and uncomment what you need:
#
#     cp .env.example .env
#
# HOW THIS FILE IS PARSED
#   Every entry point (argus CLI, argus-web, the scheduler, pytest) calls
#   argus.settings.get_settings(), which first runs
#   argus.envfile.load_process_env(). That folds this file into the process
#   environment, where two consumers pick values up:
#     - ARGUS_*  keys        -> pydantic-settings (argus/settings.py,
#                               env_prefix="ARGUS_"; ARGUS_LLM sets `llm`, …)
#     - AZURE_OPENAI_* keys  -> read directly from os.environ by the model
#                               factory (argus/llm/factory.py, AD-10)
#
# PRECEDENCE (lowest -> highest)
#   built-in defaults  <  this file  <  your shell exports
#                      <  <data>/webapp/overrides.env   (the web console's
#                         Settings page — wins on purpose, so a value saved
#                         in the UI takes effect everywhere, cron included)
#
#   i.e. this file fills gaps; it never overrides a variable you exported.
#
# `.env` is gitignored — it may hold the Azure key. Run commands from the
# repository root (paths below resolve relative to the working directory).
# =============================================================================


# --- Engine mode -------------------------------------------------------------
# azure = production models. stub/hashing = deterministic offline mode: the
# full pipeline (registry scoping, snapshots, verdicts, citation enforcement,
# manifests, replay) with no API calls — ideal for a first run.
#ARGUS_LLM=azure                     # azure | stub
#ARGUS_EMBEDDER=azure                # azure | hashing
#ARGUS_HASHING_DIM=256               # offline embedder dimension (hashing mode)

# --- Azure OpenAI (required when the mode above is azure) ---------------------
# The factory refuses to start without endpoint/key/version. api_version and
# the deployment names are pinned into every run manifest for audit.
#ARGUS_AZURE_AUTH=api_key           # api_key | default_credential (Entra ID via
                                    #   DefaultAzureCredential: managed identity,
                                    #   workload identity, az login. Needs
                                    #   `pip install -e ".[entra]"`; the API key
                                    #   below is then not required.)
#AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
#AZURE_OPENAI_API_KEY=<key>          # secret — keep .env out of git (it is)
#AZURE_OPENAI_API_VERSION=2024-10-21
#ARGUS_AZURE_SYNTHESIS_DEPLOYMENT=gpt-strong        # writing + planning
#ARGUS_AZURE_UTILITY_DEPLOYMENT=gpt-mini            # extraction · pairing · entailment
#ARGUS_AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# --- Storage -----------------------------------------------------------------
# All empty values derive sensible dev defaults under the data directory.
# These three are bound at process start (the console flags them
# "restart required" if changed while running).
#ARGUS_DATA_DIR=data                 # snapshots/ · briefs/ · dev SQLite · embedded Qdrant
#ARGUS_DB_URL=                       # empty -> sqlite:///<data>/argus.db · postgres in prod
#ARGUS_QDRANT_URL=                   # empty -> embedded local index (single process!)
#ARGUS_COLLECTION=argus_chunks       # bump to start a fresh index (e.g. new embedder)
#ARGUS_CHECKPOINT_URL=               # empty -> SQLite · postgresql://… needs the [postgres] extra

# --- Trust config locations ---------------------------------------------------
#ARGUS_REGISTRY_PATH=registry/sources.yaml
#ARGUS_DOMAINS_DIR=domains

# --- Run tuning (take effect on the next run) ---------------------------------
#ARGUS_BRIEF_MAX_STORIES=20          # citable universe cap: stories per brief
#ARGUS_BRIEF_CHUNKS_PER_STORY=3      # evidence chunks per story
#ARGUS_VERIFY_MAX_RETRIES=2          # synthesis rewrites before failed sentences drop
#ARGUS_EVENT_MATCH_JACCARD=0.5       # heuristic event pairing threshold (stub mode)
#ARGUS_RESEARCH_MAX_EVIDENCE=40      # deep-research evidence cap
#ARGUS_RESEARCH_SUB_QUESTIONS_MAX=4  # planner decomposition cap
#ARGUS_CHUNK_SIZE=1600               # ingestion chunking (chars)
#ARGUS_CHUNK_OVERLAP=200

# --- Web console (the [webapp] extra) -----------------------------------------
#ARGUS_WEB_HOST=127.0.0.1            # bind address — read at argus-web startup
#ARGUS_WEB_PORT=8765
#ARGUS_WEB_PASSWORD=                 # set to require sign-in (checked per request)
#ARGUS_WEBAPP_STATE=                 # relocate <data>/webapp (overrides.env, scheduler.json)

# --- Tests ---------------------------------------------------------------------
#ARGUS_TEST_POSTGRES_URL=            # enables the live Postgres checkpointer test
